{
  "id": "ai-research-dataset",
  "name": "AI Research - Dataset-Centric",
  "description": "For dataset construction, benchmark creation, and data-centric AI studies",
  "domain": "ai-research",
  "category": "ai-research",
  "format": "research-brief-json",
  "fileName": "research_brief.json",
  "metaFields": [
    { "key": "title", "label": "Paper Title", "path": "meta.title", "placeholder": "Optional project title" },
    { "key": "lead_author", "label": "Lead Author", "path": "meta.lead_author", "placeholder": "Optional lead author" },
    { "key": "target_venue", "label": "Target Venue", "path": "meta.target_venue", "placeholder": "Optional venue" }
  ],
  "sectionFields": {
    "ideation": [
      { "key": "research_goal", "label": "Research Goal", "path": "sections.ideation.research_goal", "placeholder": "What bottleneck does this dataset solve?" },
      { "key": "problem_framing", "label": "Problem Framing", "path": "sections.ideation.problem_framing", "placeholder": "Define scope, users, and boundaries" },
      { "key": "evidence_plan", "label": "Evidence Plan", "path": "sections.ideation.evidence_plan", "placeholder": "Key references and gap analysis" },
      { "key": "success_criteria", "label": "Success Criteria", "path": "sections.ideation.success_criteria", "type": "array", "placeholder": "One criterion per line" }
    ],
    "experiment": [
      { "key": "hypothesis_or_validation_goal", "label": "Validation Goal", "path": "sections.experiment.hypothesis_or_validation_goal", "placeholder": "What should experiments validate?" },
      { "key": "dataset_or_data_source", "label": "Data Source Plan", "path": "sections.experiment.dataset_or_data_source", "placeholder": "Collection source and protocol" },
      { "key": "method_or_protocol", "label": "Construction Protocol", "path": "sections.experiment.method_or_protocol", "placeholder": "Annotation, cleaning, governance" },
      { "key": "evaluation_plan", "label": "Evaluation Plan", "path": "sections.experiment.evaluation_plan", "placeholder": "Metrics, baselines, ablations" }
    ],
    "publication": [
      { "key": "paper_outline", "label": "Paper Outline", "path": "sections.publication.paper_outline", "placeholder": "Dataset story and contribution boundaries" },
      { "key": "figures_tables_plan", "label": "Figures/Tables Plan", "path": "sections.publication.figures_tables_plan", "placeholder": "Leaderboards, data cards, comparisons" },
      { "key": "artifact_plan", "label": "Artifact Plan", "path": "sections.publication.artifact_plan", "placeholder": "README, license, release assets" },
      { "key": "submission_checklist", "label": "Submission Checklist", "path": "sections.publication.submission_checklist", "type": "array", "placeholder": "One item per line" }
    ]
  },
  "pipeline": {
    "version": "1.1",
    "mode": "idea",
    "stages": {
      "ideation": {
        "required_elements": [
          "sections.ideation.research_goal",
          "sections.ideation.problem_framing"
        ],
        "optional_elements": [
          "sections.ideation.evidence_plan",
          "sections.ideation.success_criteria"
        ],
        "quality_gate": [
          "Dataset scope, target users, and use restrictions are explicit",
          "Value over existing datasets is articulated"
        ],
        "task_blueprints": [
          {
            "id": "dataset_problem_and_scope",
            "title": "Define dataset problem statement and scope boundaries",
            "description": "Specify target use-cases, inclusion/exclusion scope, and risk boundaries.",
            "taskType": "analysis",
            "recommended_skills": ["inno-research-orchestrator"]
          },
          {
            "id": "dataset_schema_and_collection_plan",
            "title": "Design schema and data collection plan",
            "description": "Define label schema, sampling strategy, and collection channels.",
            "taskType": "exploration",
            "recommended_skills": ["inno-idea-generation", "inno-research-orchestrator"]
          }
        ],
        "recommended_skills": [
          "inno-idea-generation",
          "inno-research-orchestrator"
        ]
      },
      "experiment": {
        "required_elements": [
          "sections.experiment.hypothesis_or_validation_goal",
          "sections.experiment.method_or_protocol",
          "sections.experiment.evaluation_plan"
        ],
        "optional_elements": [
          "sections.experiment.dataset_or_data_source"
        ],
        "quality_gate": [
          "Annotation/cleaning protocol is reproducible",
          "Benchmark and baseline plan are executable"
        ],
        "task_blueprints": [
          {
            "id": "dataset_annotation_and_qc_protocol",
            "title": "Specify annotation, cleaning, and quality-control protocol",
            "description": "Define annotation guidelines, inter-annotator checks, and curation flow.",
            "taskType": "implementation",
            "recommended_skills": ["inno-experiment-dev"]
          },
          {
            "id": "dataset_baseline_and_benchmark_plan",
            "title": "Run baseline benchmark plan and error analysis",
            "description": "Establish baseline models/heuristics, evaluate, and summarize failure patterns.",
            "taskType": "analysis",
            "recommended_skills": ["inno-experiment-analysis"]
          }
        ],
        "recommended_skills": [
          "inno-experiment-dev",
          "inno-experiment-analysis"
        ]
      },
      "publication": {
        "required_elements": [
          "sections.publication.paper_outline",
          "sections.publication.submission_checklist"
        ],
        "optional_elements": [
          "sections.publication.figures_tables_plan",
          "sections.publication.artifact_plan"
        ],
        "quality_gate": [
          "Data card and governance statements are complete",
          "Release artifacts and benchmark tables are publication-ready"
        ],
        "task_blueprints": [
          {
            "id": "dataset_documentation_and_datacard",
            "title": "Prepare dataset documentation and data card",
            "description": "Draft dataset statement, bias/safety notes, and intended-use guidance.",
            "taskType": "writing",
            "recommended_skills": ["inno-paper-writing"]
          },
          {
            "id": "dataset_release_and_submission_bundle",
            "title": "Finalize release bundle and submission package",
            "description": "Assemble benchmark tables, README/license, and supplementary artifacts.",
            "taskType": "writing",
            "recommended_skills": ["inno-paper-writing", "inno-reference-audit"]
          }
        ],
        "recommended_skills": [
          "inno-paper-writing",
          "inno-reference-audit"
        ]
      }
    }
  }
}
