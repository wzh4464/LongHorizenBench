+    public void testFileEmptyString() {
+        assertThrowsWithMessage(ConfigException.class, () -> testFile(""), "must not contain only whitespace");
+    }
+
+    @Test
+    public void testFileWhitespace() {
+        assertThrowsWithMessage(ConfigException.class, () -> testFile("    "), "must not contain only whitespace");
+    }
