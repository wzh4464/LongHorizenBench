+				false, nil), nil)
+			if tc.expectError == "" {
+				if err != nil {
+					t.Errorf("Unexpected error: %v", err)
+				}
+				if tc.expectActions != nil {
+					if len(kubeClient.Actions()) == 0 {
+						t.Errorf("Expected a client action")
+					}
+				} else {
+					if len(kubeClient.Actions()) > 0 {
+						t.Errorf("Got client action(s) when not expected")
