+        base.addFirst(e);
+        return true;
+    }
+
+    public boolean addAll(Collection<? extends E> c) {
+        boolean modified = false;
+        for (E e : c) {
+            base.addFirst(e);
+            modified = true;
+        }
+        return modified;
+    }
+
