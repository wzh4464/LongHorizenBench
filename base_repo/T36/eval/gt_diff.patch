+        assertThrows(UOE, () -> view.removeLast());
+
+        var rview = view.reversed();
+        checkUnmodifiableView(rview);
+        assertThrows(UOE, () -> rview.removeFirst());
+        assertThrows(UOE, () -> rview.removeLast());
+    }
