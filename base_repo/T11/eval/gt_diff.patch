--- /dev/null
+++ b/tests/cases/conformance/esDecorators/metadata/esDecoratorsMetadata3.ts
@@ -0,0 +1,22 @@
+// @target: es2022,es2015
+// @noTypesAndSymbols: true
+// @lib: esnext
+// @filename: /foo.ts
+
+function appendMeta(key: string, value: string) {
+    return (_, context) => {
+        const existing = context.metadata[key] ?? [];
+        context.metadata[key] = [...existing, value];
+    };
+}
+
+@appendMeta('a', 'x')
+class C {
+}
+
+@appendMeta('a', 'z')
+class D extends C {
+}
+
+C[Symbol.metadata].a; // ['x']
+D[Symbol.metadata].a; // ['x', 'z']
