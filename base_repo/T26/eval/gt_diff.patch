-             cp->tag_at(cp_index).is_method() ||
-             cp->tag_at(cp_index).is_interface_method()) {
-    int klass_cp_index = cp->uncached_klass_ref_index_at(cp_index);
-    if (!cp->tag_at(klass_cp_index).is_klass()) {
-      // Not yet resolved
