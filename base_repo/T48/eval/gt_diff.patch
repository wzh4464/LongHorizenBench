+//// [mappedTypeAsClauses.ts]
+// Mapped type 'as N' clauses
+
+type Getters<T> = { [P in keyof T & string as `get${capitalize P}`]: () => T[P] };
+type TG1 = Getters<{ foo: string, bar: number, baz: { z: boolean } }>;
