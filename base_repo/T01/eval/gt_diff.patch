+    private static class PermitAllTraffic implements NetworkFilter {
+
+        @Override
+        public boolean acceptInbound(RaftMessage message) {
+            return true;
+        }
+
+        @Override
+        public boolean acceptOutbound(RaftMessage message) {
+            return true;
