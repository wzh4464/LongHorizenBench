+    private VoteResponseData buildVoteResponse(Errors partitionLevelError, boolean voteGranted) {
+        return VoteResponse.singletonResponse(
+            Errors.NONE,
+            log.topicPartition(),
+            partitionLevelError,
+            quorum.epoch(),
+            quorum.leaderIdOrNil(),
+            voteGranted);
+    }
