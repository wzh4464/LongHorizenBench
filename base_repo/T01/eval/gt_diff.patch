+    private FetchResponseData buildEmptyFetchResponse(
+        Errors error,
+        Optional<LogOffsetMetadata> highWatermark
+    ) {
+        return buildFetchResponse(error, MemoryRecords.EMPTY, Optional.empty(), highWatermark);
+    }
