+            this.nodeId = nodeId;
+            this.client = client;
+            this.log = log;
+            this.channel = channel;
+            this.store = store;
+            this.quorum = quorum;
+            this.logContext = logContext;
+            this.counter = new ReplicatedCounter(nodeId, client, logContext);
