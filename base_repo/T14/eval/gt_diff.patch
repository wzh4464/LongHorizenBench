+}
+
+- (instancetype)initWithState:(jint)state {
+    self = [super init];
+    if (self) {
+        _paintState = state;
+    }
+    return self;
+}
+
+- (BOOL)isEqual:(MTLPaint *)other {
+    if (other == self)
+        return YES;
+    if (!other || ![other isKindOfClass:[self class]])
+        return NO;
+    return _paintState == other->_paintState;
+}
