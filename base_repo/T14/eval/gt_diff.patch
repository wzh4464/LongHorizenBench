+            return NULL;
+        }
+    }
+
+    // make the context current
+    MTLSDOps *dstMTLOps = (MTLSDOps *)dstOps->privOps;
+    mtlc = dstMTLOps->configInfo->context;
+
+    if (mtlc == NULL) {
+        J2dRlsTraceLn(J2D_TRACE_ERROR,
+                      "MTLContext_SetSurfaces: could not make context current");
+        return NULL;
+    }
+
+    return mtlc;
+}
