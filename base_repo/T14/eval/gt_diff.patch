+@interface MTLSamplerManager : NSObject
+- (id _Nonnull)initWithDevice:(_Nonnull id<MTLDevice>) device;
+- (void)dealloc;
+
+- (void) setSamplerWithEncoder:(_Nonnull id<MTLRenderCommandEncoder>) encoder
