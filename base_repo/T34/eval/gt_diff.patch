+			},
+		},
+		{
+			name: "no batching empty sign",
+			pods: []podDef{
+				{
+					name:         "esg-batchp1",
+					expectedNode: "esg-batchn1",
+					nodeAffinity: []string{"esg-batchn1", "esg-batchn2", "esg-batchn3"},
+					scheduler:    "emptysign",
+				},
+				{
+					name:         "esg-batchp2",
+					expectedNode: "esg-batchn2",
+					nodeAffinity: []string{"esg-batchn1", "esg-batchn2", "esg-batchn3"},
+					scheduler:    "emptysign",
