-    }
-  }
-  virtual void do_oop(oop* p) {
-    oop v = *p;
-    if(v != nullptr) {
-      uintptr_t u = cast_from_oop<uintptr_t>(v);
-      ArchiveHeapLoader::assert_in_loaded_heap(u);
