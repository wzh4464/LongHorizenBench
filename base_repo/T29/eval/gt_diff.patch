+
+// The following are offsets from buffer_bottom()
+size_t AOTStreamedHeapWriter::_buffer_used;
+size_t AOTStreamedHeapWriter::_roots_offset;
+size_t AOTStreamedHeapWriter::_forwarding_offset;
