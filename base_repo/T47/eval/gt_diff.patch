diff --git a/test/hotspot/jtreg/runtime/cds/appcds/aotFlags/FileNameSubstitution.java b/test/hotspot/jtreg/runtime/cds/appcds/aotFlags/FileNameSubstitution.java
new file mode 100644
index 00000000000..23b82b124d9
--- /dev/null
+++ b/test/hotspot/jtreg/runtime/cds/appcds/aotFlags/FileNameSubstitution.java
@@ -0,0 +1,207 @@
+/*
