+	// only compare relevant changes b/c of difference in metadata
+	if !apiequality.Semantic.DeepEqual(claim.Status, claimOut.Status) {
+		t.Errorf("unexpected object: %s", diff.ObjectDiff(claim.Status, claimOut.Status))
+	}
