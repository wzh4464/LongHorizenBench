+		Strategy.PrepareForUpdate(ctx, newPodScheduling, podScheduling)
+		errs := Strategy.ValidateUpdate(ctx, newPodScheduling, podScheduling)
+		if len(errs) == 0 {
+			t.Errorf("expected a validation error")
+		}
+	})
+}
