+func testClaim(name, namespace string, spec resource.ResourceClaimSpec) *resource.ResourceClaim {
+	return &resource.ResourceClaim{
+		ObjectMeta: metav1.ObjectMeta{
+			Name:      name,
+			Namespace: namespace,
+		},
+		Spec: spec,
+	}
