+
+uintptr_t ZStackWatermark::prev_frame_color(const frame& fr) const {
+  for (int i = _old_watermarks_newest; i >= 0; i--) {
+    const ZColorWatermark ow = _old_watermarks[i];
+    if (ow._watermark == 0 || uintptr_t(fr.sp()) <= ow._watermark) {
+      return ow._color;
+    }
