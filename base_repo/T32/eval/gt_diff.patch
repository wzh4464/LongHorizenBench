+#ifndef SHARE_GC_X_XHASH_INLINE_HPP
+#define SHARE_GC_X_XHASH_INLINE_HPP
+
+#include "gc/x/xHash.hpp"
+
+#include "gc/x/xAddress.inline.hpp"
+
+inline uint32_t XHash::uint32_to_uint32(uint32_t key) {
+  key = ~key + (key << 15);
+  key = key ^ (key >> 12);
+  key = key + (key << 2);
+  key = key ^ (key >> 4);
+  key = key * 2057;
+  key = key ^ (key >> 16);
+  return key;
+}
+
+inline uint32_t XHash::address_to_uint32(uintptr_t key) {
+  return uint32_to_uint32((uint32_t)(key >> 3));
+}
+
+#endif // SHARE_GC_X_XHASH_INLINE_HPP
