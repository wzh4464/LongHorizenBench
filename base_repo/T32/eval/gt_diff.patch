+static ZMemoryUsageInfo compute_memory_usage_info() {
+  const size_t capacity = ZHeap::heap()->capacity();
+  const size_t old_used = ZHeap::heap()->used_old();
+  const size_t young_used = ZHeap::heap()->used_young();
