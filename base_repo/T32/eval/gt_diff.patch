+  // Previous watermark
+  const uintptr_t prev_watermark = StackWatermarkState::is_done(_state) ? 0 : last_processed_raw();
+
+  // Create a new color watermark to describe the old watermark
+  const ZColorWatermark cw = { prev_color, prev_watermark };
