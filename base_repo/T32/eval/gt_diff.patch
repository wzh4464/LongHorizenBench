+    munmap((void*)res, size);
+    return false;
+  }
+
+  // Success
+  return true;
+}
+
+void XVirtualMemoryManager::pd_unreserve(uintptr_t addr, size_t size) {
+  const int res = munmap((void*)addr, size);
+  assert(res == 0, "Failed to unmap memory");
+}
