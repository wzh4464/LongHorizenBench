+
+    @Run(test = {"testAllocateArrayThenStoreAtKnownIndex",
+                 "testAllocateArrayThenStoreAtUnknownIndex",
+                 "testArrayLoadThenLoad",
+                 "testArrayStoreThenStore",
+                 "testArrayStoreThenLoad"})
+    void runArrayTests() {
