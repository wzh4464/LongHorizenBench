+void ZDriverPort::send_async(const ZDriverRequest& message) {
+  ZLocker<ZConditionLock> locker(&_lock);
+  if (!_has_message) {
+    // Post message
+    _message = message;
+    _has_message = true;
+    _lock.notify();
+  }
