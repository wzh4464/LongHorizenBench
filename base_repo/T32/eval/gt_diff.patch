+  pmem0.add_segment(XPhysicalMemorySegment(20, 10, true));
+  pmem0.add_segment(XPhysicalMemorySegment(30, 10, false));
+  EXPECT_EQ(pmem0.nsegments(), 4);
+  EXPECT_EQ(pmem0.size(), 40u);
