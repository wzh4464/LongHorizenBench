+  ZMemoryUsageInfo info;
+  info._old_used = MIN2(old_used, capacity);
+  info._old_capacity = info._old_used;
+  info._young_capacity = capacity - info._old_capacity;
+  info._young_used = MIN2(young_used, info._young_capacity);
+  return info;
+}
