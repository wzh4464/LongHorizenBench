+
+  pmem.add_segment(XPhysicalMemorySegment(10, 10, true));
+  pmem.add_segment(XPhysicalMemorySegment(30, 10, true));
+  pmem.add_segment(XPhysicalMemorySegment(50, 10, true));
+  EXPECT_EQ(pmem.nsegments(), 3);
