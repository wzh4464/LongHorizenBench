+MemoryUsage XServiceabilityMemoryPool::get_memory_usage() {
+  const size_t committed = XHeap::heap()->capacity();
+  const size_t used      = MIN2(XHeap::heap()->used(), committed);
+
+  return MemoryUsage(initial_size(), used, committed, max_size());
+}
