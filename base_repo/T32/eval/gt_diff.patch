+  int get_stub_size();
+public:
+  static ZLoadBarrierStubC2Aarch64* create(const MachNode* node, Address ref_addr, Register ref, int offset);
+
+  virtual void emit_code(MacroAssembler& masm);
+  bool is_test_and_branch_reachable();
+  Label* entry();
+};
