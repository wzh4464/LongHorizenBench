+void XStatUnitOpsPerSecond(LogTargetHandle log, const XStatSampler& sampler, const XStatSamplerHistory& history) {
+  log.print(" %10s: %-41s "
+            UINT64_FORMAT_W(9) " / " UINT64_FORMAT_W(-9) " "
