+				NodeName:             "node-1",
+				NodeUID:              types.UID("node-uid-1"),
+				MaxExpirationSeconds: ptr.To[int32](86400),
+				PKIXPublicKey:        ed25519PubPKIX1,
+				ProofOfPossession:    ed25519Proof1,
+			},
