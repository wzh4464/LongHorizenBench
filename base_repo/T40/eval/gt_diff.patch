+			desc: "No errors when the caller is authorized",
+			oldPCR: &certificates.PodCertificateRequest{
+				ObjectMeta: metav1.ObjectMeta{
+					Namespace:       "foo",
+					Name:            "bar",
+					ResourceVersion: "1",
