+	src.checkAndReload()
+
+	hooks := src.Hooks()
+	if len(hooks) != 1 {
+		t.Fatalf("Hooks() returned %d hooks after error reload, want 1", len(hooks))
+	}
+	if hooks[0].Policy.Name != "policy1" {
+		t.Errorf("hook policy name = %q, want %q", hooks[0].Policy.Name, "policy1")
+	}
+}
