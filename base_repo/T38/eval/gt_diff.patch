+  validationActions:
+  - Deny
+`,
+			},
+			wantErr:        true,
+			wantErrContain: "paramRef",
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			// Create temp directory
+			dir := t.TempDir()
+
+			// Create files
+			for name, content := range tt.files {
+				path := filepath.Join(dir, name)
