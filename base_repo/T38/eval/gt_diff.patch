+			RecordLastConfigInfo(tc.manifestType, tc.apiServerID, tc.configData)
+
+			provider := configHashProviders[tc.manifestType]
+			hashes := provider.GetCurrentHashes()
+			if len(hashes) < 2 {
+				t.Fatalf("expected at least 2 hashes, got %d", len(hashes))
