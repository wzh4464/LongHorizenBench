+kind: ValidatingAdmissionPolicy
+metadata:
+  name: no-suffix
+spec:
+  matchConstraints:
+    resourceRules:
+    - apiGroups: [""]
+      apiVersions: ["v1"]
+      operations: ["CREATE"]
+      resources: ["pods"]
+  validations:
+  - expression: "true"
+`,
+			},
+			wantErr:        true,
+			wantErrContain: "must have a name ending with",
+		},
+		{
+			name: "duplicate policy names",
+			files: map[string]string{
+				"01-policy.yaml": `
