+			),
+		},
+		UpdatedAt: time.Now().UTC(),
+	}
+
+	{ // This should fail since we don't have write perms.
+		args := structs.FederationStateRequest{
+			Datacenter:   "dc1",
+			Op:           structs.FederationStateUpsert,
+			State:        expected,
+			WriteRequest: structs.WriteRequest{Token: opReadToken.SecretID},
