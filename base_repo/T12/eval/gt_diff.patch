+				var out structs.IndexedNodes
+				require.NoError(t, srv.RPC("Catalog.ListNodes", &arg, &out))
+				require.Len(t, out.Nodes, 1)
+				node := out.Nodes[0]
+				require.Equal(t, dstDC, node.Datacenter)
+				require.Equal(t, names[dstDC], node.Node)
+			})
+		}
+	}
+}
