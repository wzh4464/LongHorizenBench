+	reqs := make([]fields.Requirement, 0, len(requirements))
+	var errs []error
+	for _, expr := range requirements {
+		if len(expr.Values) > 1 {
+			errs = append(errs, fmt.Errorf("fieldSelectors do not yet support multiple values"))
+			continue
+		}
