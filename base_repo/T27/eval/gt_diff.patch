+                _Py_DECLARE_STR(empty, "");
+                PyTuple_SET_ITEM(strings, stringsidx++, &_Py_STR(empty));
+            }
+            PyTuple_SET_ITEM(interpolations, interpolationsidx++, Py_NewRef(item));
+            last_was_str = 0;
+        }
+    }
+    if (!last_was_str) {
+        _Py_DECLARE_STR(empty, "");
+        PyTuple_SET_ITEM(strings, stringsidx++, &_Py_STR(empty));
+    }
